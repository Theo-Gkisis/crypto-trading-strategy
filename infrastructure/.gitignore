# =============================================================================
# Terraform — files that must NOT be committed to git
# =============================================================================

# Secret values (contain API keys!)
terraform.tfvars
*.tfvars
!terraform.tfvars.example  # Safe to commit — contains no real secrets

# Terraform state — contains the full infrastructure state
# (may include secrets in plaintext)
*.tfstate
*.tfstate.*
.terraform.tfstate.lock.info

# Terraform working directory (downloaded providers & modules)
.terraform/
.terraform.lock.hcl

# Crash logs
crash.log
crash.*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Plan output files (may contain secrets)
*.tfplan
