# ============================================================
# BINANCE API KEYS
# Πήγαινε: Binance → Profile → API Management → Create API
# ============================================================
BINANCE_API_KEY=your_api_key_here
BINANCE_API_SECRET=your_api_secret_here

# ============================================================
# TELEGRAM BOT
# 1. Άνοιξε Telegram → @BotFather → /newbot
# 2. Αντέγραψε το token εδώ
# 3. Για το chat_id: @userinfobot
# ============================================================
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ============================================================
# BOT SETTINGS
# ============================================================
TRADING_MODE=testnet
TOTAL_CAPITAL=100
